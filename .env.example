# 1 = deterministic local demo mode (default), 0 = real Gemini mode
DEMO_MODE=1

# Required when DEMO_MODE=0
GEMINI_API_KEY=your_gemini_api_key_here

# Optional override for Gemini model name
# Default in code: gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash

# Required when starting Telegram in real mode
# Optional in demo mode (without it, CLI runs a local Telegram simulator)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Logging verbosity: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
